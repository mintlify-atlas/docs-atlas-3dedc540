{
  "projectType": "saas",
  "projectName": "Buildstory",
  "projectDescription": "Automatically capture the story of what you build with AI-enriched commit tracking and public project timelines",
  "theme": "palm",
  "primaryColor": "#3B82F6",
  "lightColor": "#60A5FA",
  "darkColor": "#2563EB",
