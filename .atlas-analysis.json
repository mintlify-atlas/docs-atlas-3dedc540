              "features/timeline",
              "features/authentication"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/installation",
              "guides/configuration",
              "guides/workflow",
              "guides/troubleshooting"
            ]
          }
        ]
      },
      {
