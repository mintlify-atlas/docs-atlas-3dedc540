      }
    ]
  },
  "keyFeatures": [
    "Automatic git commit tracking via post-commit hooks",
    "AI-powered enrichment of commits into human-readable updates",
    "Web dashboard for reviewing and managing project updates",
    "Public timeline for sharing your development journey",
    "Browser-based CLI authentication flow",
    "Secret redaction and configurable file exclusions",
    "Multi-project support with per-user API keys"
  ],
  "publicApiSurface": [
    "buildstory auth",
    "buildstory init",
    "buildstory status",
    "POST /api/v1/ingest",
    "POST /api/v1/projects",
    "GET /api/v1/projects/[id]",
    "POST /api/v1/projects/[id]/entries/check",
    "GET /api/v1/projects/[id]/drafts",
    "GET /api/v1/projects/[id]/timeline",
    "PATCH /api/v1/updates/[entryId]",
    "POST /api/v1/updates/[entryId]/approve",
    "POST /api/v1/updates/[entryId]/dismiss",
    "POST /api/v1/updates/bulk-approve",
    "POST /api/v1/api-keys",
    "GET /api/v1/api-keys",
    "DELETE /api/v1/api-keys/[id]"
  ]
