{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Buildstory",
  "theme": "palm",
  "colors": {
    "primary": "#3B82F6",
    "light": "#60A5FA",
    "dark": "#2563EB"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/coppinger/buildstory"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/coppinger/buildstory"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart"]
          },
          {
            "group": "Features",
            "pages": [
              "features/ai-enrichment",
              "features/dashboard",
              "features/timeline",
              "features/authentication"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/installation",
              "guides/configuration",
              "guides/workflow",
              "guides/troubleshooting"
            ]
          }
        ]
      },
      {
        "tab": "CLI Reference",
        "groups": [
          {
            "group": "Commands",
            "pages": [
              "cli/overview",
              "cli/auth",
              "cli/init",
              "cli/status"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "cli/credentials",
              "cli/config-files",
              "cli/buildstoryignore"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["api/overview", "api/authentication"]
          },
          {
            "group": "Projects",
            "pages": [
              "api/projects/create",
              "api/projects/get",
              "api/projects/check-entries"
            ]
          },
          {
            "group": "Commits",
            "pages": ["api/commits/ingest"]
          },
          {
            "group": "Updates",
            "pages": [
              "api/updates/list-drafts",
              "api/updates/timeline",
              "api/updates/edit",
              "api/updates/approve",
              "api/updates/dismiss",
              "api/updates/bulk-approve"
            ]
          },
          {
            "group": "API Keys",
            "pages": [
              "api/keys/create",
              "api/keys/list",
              "api/keys/revoke"
            ]
          }
        ]
      }
    ]
  }
}
